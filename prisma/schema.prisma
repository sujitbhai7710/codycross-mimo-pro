generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model DailyAnswer {
  id        String   @id @default(cuid())
  date      String   @unique
  puzzleData String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
